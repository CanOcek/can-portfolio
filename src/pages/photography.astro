---
import BaseLayout from "../layouts/BaseLayout.astro";
import PhotoLightbox from "../components/PhotoLightbox.astro";
import PhotoTile from "../components/PhotoTile.astro";

const selectedWork = [
  {
    src: "/images/photography/live-music/wonuola-crowd-perspective.jpg",
    title: "Audience-facing performance",
    category: "Live music",
    alt: "A vocalist seen from behind while performing to a small concert audience.",
    caption: "A quiet audience-facing frame with venue atmosphere and performer context.",
    orientation: "wide",
    prominent: true,
  },
  {
    src: "/images/photography/live-music/emanate-vocal-close.jpg",
    title: "Close performance moment",
    category: "Live music",
    alt: "A vocalist singing intensely into a microphone with band members behind him.",
    caption: "Fast movement, low light, and expression at the decisive moment.",
    orientation: "wide",
    prominent: true,
  },
  {
    src: "/images/photography/live-music/noah-juan-vocal-guitar.jpg",
    title: "Vocal and guitar performance",
    category: "Artist portrait",
    alt: "A singer performing into a microphone while a guitarist plays behind him.",
    caption: "Readable expression and enough stage context for artist-facing use.",
    orientation: "landscape",
  },
  {
    src: "/images/photography/live-music/steikon-drummer.jpg",
    title: "Drummer under stage light",
    category: "Live music",
    alt: "A drummer playing under blue and red stage lighting.",
    caption: "Instrument-focused coverage with clear color separation and motion.",
    orientation: "landscape",
  },
  {
    src: "/images/photography/live-music/event-audio-desk.jpg",
    title: "Event production detail",
    category: "Documentary",
    alt: "A DJ and audio setup with laptops, mixer, turntables, and a crowd in the background.",
    caption: "The technical layer around a performance: tools, timing, and room energy.",
    orientation: "landscape",
  },
  {
    src: "/images/photography/live-music/performer-crowd-rapport.jpg",
    title: "Performer and crowd",
    category: "Events",
    alt: "A performer seen from behind while addressing a crowd in warm stage lighting.",
    caption: "Audience energy and performer presence in the same frame.",
    orientation: "wide",
  },
  {
    src: "/images/photography/live-music/wonuola-stage-angle.jpg",
    title: "Stage angle",
    category: "Live music",
    alt: "A vocalist performing on a small stage from a tilted overhead angle.",
    caption: "A more graphic composition for variety inside the concert set.",
    orientation: "landscape",
  },
] as const;

const categories = [
  {
    title: "Live Music & Events",
    meta: "Concerts, performances, trade shows",
    body: "Concert photography is the strongest foundation: difficult light, changing scenes, fast subjects, and moments that cannot be repeated. That experience also translates naturally into event and trade-show coverage.",
  },
  {
    title: "Portraits & People",
    meta: "Artists, founders, personal branding",
    body: "Portrait work focuses on expression, setting, and practical usage. The aim is to create images that feel specific to the person and still work across press, web, and social formats.",
  },
  {
    title: "Product & Brand",
    meta: "Products, details, creative businesses",
    body: "Product and brand work covers hero images, craftsmanship details, workshop scenes, and visual storytelling for boutique or creative brands.",
  },
] as const;

const guitarSeries = [
  {
    title: "Guitar hero image",
    category: "Product",
    alt: "Placeholder for a hero photograph of an Ocek guitar.",
    caption: "A clean product image built around shape, finish, and character.",
    orientation: "wide",
    prominent: true,
  },
  {
    title: "Product detail",
    category: "Craft",
    alt: "Placeholder for a close-up product detail of a guitar.",
    caption: "Hardware, wood grain, finish, and the details that make the object feel handmade.",
    orientation: "square",
  },
  {
    title: "Workshop photograph",
    category: "Process",
    alt: "Placeholder for a workshop photograph showing guitar-making tools and materials.",
    caption: "Documentary images of the space, tools, and making process.",
    orientation: "landscape",
  },
  {
    title: "Maker portrait",
    category: "Portrait",
    alt: "Placeholder for a portrait of the maker behind the instruments.",
    caption: "A portrait that connects the instrument to the person and the craft.",
    orientation: "portrait",
  },
  {
    title: "Trade-show image",
    category: "Event",
    alt: "Placeholder for a guitar brand trade-show or event photograph.",
    caption: "Product presentation, booth context, and customer interaction.",
    orientation: "landscape",
  },
] as const;

const skills = [
  "Concert and event photography",
  "Low-light photography",
  "Portrait photography",
  "Product and detail photography",
  "Visual storytelling",
  "Composition and lighting",
  "Image selection and post-production",
  "Web and social-media-ready delivery",
];
---

<BaseLayout
  title="Photography"
  description="Photography portfolio page for Can Ocek, covering live music, portraits, products, creative brands, and documentary-style event coverage."
>
  <header class="photography-hero container" aria-labelledby="photography-title">
    <div class="photography-hero__content">
      <p class="eyebrow">Photography</p>
      <h1 id="photography-title">Photography</h1>
      <p class="lede">
        I photograph people, performances, products, and creative environments. Concert photography
        trained me to work with difficult lighting, fast-moving subjects, and moments that cannot
        be recreated.
      </p>
      <div class="button-row">
        <a class="button primary" href="#selected-work">Selected work</a>
        <a class="button" href="/contact/">Contact</a>
      </div>
    </div>
    <figure class="photography-hero__visual">
      <button
        class="photography-hero__trigger"
        type="button"
        aria-label="Open photo: Live music cover"
        data-lightbox-trigger
        data-lightbox-src="/images/photography/live-music/featured-live-crowd.jpg"
        data-lightbox-alt="A vocalist performing in a small venue while the crowd watches under low stage lighting."
        data-lightbox-title="Live music cover"
        data-lightbox-category="Portfolio cover"
        data-lightbox-caption="Concert photography in difficult light, with the room and the moment kept intact."
      >
        <img
          src="/images/photography/live-music/featured-live-crowd.jpg"
          alt="A vocalist performing in a small venue while the crowd watches under low stage lighting."
          loading="eager"
        />
      </button>
      <figcaption>
        <span>Portfolio cover</span>
        <strong>Live music cover</strong>
      </figcaption>
    </figure>
  </header>

  <section class="section" id="selected-work" aria-labelledby="selected-work-title">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Selected work</p>
        <h2 id="selected-work-title">Selected concert work</h2>
      </div>
      <div class="photo-grid">
        {selectedWork.map((item) => <PhotoTile {...item} />)}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="photo-categories-title">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Range</p>
        <h2 id="photo-categories-title">Photography categories</h2>
      </div>
      <div class="grid three section-offset">
        {
          categories.map((category) => (
            <article class="panel">
              <p class="panel__meta">{category.meta}</p>
              <h3>{category.title}</h3>
              <p>{category.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--media" aria-labelledby="guitars-title">
    <div class="container visual-series">
      <div class="visual-series__intro">
        <p class="eyebrow">Featured visual series</p>
        <h2 id="guitars-title">&Ouml;cek Guitars</h2>
        <p class="lede">
          Product and brand photography for a guitar-making context.
        </p>
        <p>
          A visual series combining product photography, craftsmanship details, workshop
          documentation, and portraits of the maker behind the instruments.
        </p>
      </div>
      <div class="series-grid">
        {guitarSeries.map((item) => <PhotoTile {...item} />)}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="photo-skills-title">
    <div class="container two-column">
      <div>
        <p class="eyebrow">Capabilities</p>
        <h2 id="photo-skills-title">What I can cover</h2>
      </div>
      <ul class="pill-list photography-skills" aria-label="Photography capabilities">
        {skills.map((skill) => <li>{skill}</li>)}
      </ul>
    </div>
  </section>

  <section class="section" aria-labelledby="photo-contact-title">
    <div class="container narrow stack">
      <p class="eyebrow">Contact</p>
      <h2 id="photo-contact-title">Available for concerts, events, portraits, and creative brand projects.</h2>
      <div class="button-row">
        <a class="button primary" href="/contact/">Contact status</a>
        <a class="button" href="/music/">Music work</a>
      </div>
    </div>
  </section>

  <PhotoLightbox />
</BaseLayout>

<style>
  .photography-hero {
    align-items: end;
    display: grid;
    gap: var(--space-7);
    grid-template-columns: minmax(0, 0.9fr) minmax(18rem, 0.68fr);
    min-height: min(760px, calc(100vh - 6rem));
    padding-block: var(--space-8);
  }

  .photography-hero__content {
    display: grid;
    gap: var(--space-5);
  }

  .photography-hero__visual {
    border-radius: 8px;
    display: grid;
    margin: 0;
    overflow: hidden;
    position: relative;
  }

  .photography-hero__trigger {
    appearance: none;
    background: transparent;
    border: 0;
    color: inherit;
    cursor: zoom-in;
    display: block;
    line-height: 0;
    margin: 0;
    outline: 0;
    padding: 0;
  }

  .photography-hero__trigger:focus-visible {
    box-shadow: 0 0 0 3px var(--color-focus) inset;
  }

  .photography-hero__visual img {
    aspect-ratio: 4 / 5;
    block-size: 100%;
    inline-size: 100%;
    object-fit: cover;
  }

  .photography-hero__visual figcaption {
    background: linear-gradient(180deg, transparent, rgb(5 6 8 / 0.76));
    display: grid;
    gap: var(--space-1);
    inset-block-end: 0;
    inset-inline: 0;
    padding: var(--space-5);
    position: absolute;
  }

  .photography-hero__visual span {
    color: var(--color-cool);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .photography-hero__visual strong {
    color: var(--color-text);
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.6vw, 2.4rem);
    font-weight: 500;
    line-height: 1.05;
  }

  .section-heading {
    max-width: var(--content-width-narrow);
  }

  .photo-grid {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(6, minmax(0, 1fr));
    margin-block-start: var(--space-6);
  }

  .photo-grid :global(.photo-tile) {
    grid-column: span 2;
  }

  .photo-grid :global(.photo-tile--wide),
  .photo-grid :global(.photo-tile--prominent) {
    grid-column: span 3;
  }

  .visual-series {
    display: grid;
    gap: var(--space-7);
  }

  .visual-series__intro {
    max-width: var(--content-width-narrow);
  }

  .visual-series__intro .lede {
    margin-block-end: var(--space-4);
  }

  .series-grid {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .series-grid :global(.photo-tile) {
    grid-column: span 2;
  }

  .series-grid :global(.photo-tile--prominent) {
    grid-column: span 3;
    grid-row: span 2;
  }

  .photography-skills {
    align-content: start;
  }

  @media (max-width: 920px) {
    .photo-grid,
    .series-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .photo-grid :global(.photo-tile),
    .photo-grid :global(.photo-tile--wide),
    .photo-grid :global(.photo-tile--prominent),
    .series-grid :global(.photo-tile),
    .series-grid :global(.photo-tile--prominent) {
      grid-column: span 1;
      grid-row: auto;
    }
  }

  @media (max-width: 820px) {
    .photography-hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-block: var(--space-7);
    }

    .photography-hero__visual img {
      aspect-ratio: 16 / 10;
    }
  }

  @media (max-width: 620px) {
    .photo-grid,
    .series-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
