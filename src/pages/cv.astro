---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="CV"
  description="A concise web CV for Can Ocek across Management & Technology, software, data systems, music production, and media."
>
  <header class="page-header container narrow">
    <p class="eyebrow">CV</p>
    <h1>CV</h1>
    <p class="lede">
      I study Management & Technology at TUM with a computer-science foundation and hands-on work
      across software, data systems, music production, media, and research-oriented technical
      projects.
    </p>
    <div class="button-row" aria-label="CV actions">
      <a class="button primary" href="/pdfs/Can%20Ocek%20CV.pdf" download>Download CV</a>
      <a class="button" href="/contact/">Contact</a>
    </div>
  </header>

  <section class="section" aria-labelledby="profile-title">
    <div class="container two-column">
      <div>
        <p class="eyebrow">Profile</p>
        <h2 id="profile-title">Profile</h2>
      </div>
      <p>
        I connect technical implementation with business context and creative production. My work
        includes a RAG-based business-development radar, algorithm and Unity projects, CRM data
        modeling, music/video production, and earlier research-oriented engineering projects.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="education-title">
    <div class="container two-column">
      <div>
        <p class="eyebrow">Education</p>
        <h2 id="education-title">Education</h2>
      </div>
      <ul class="meta-list">
        <li>
          <strong>Technical University of Munich</strong>
          <p>B.Sc. Management & Technology, 10/2023 - ongoing.</p>
        </li>
        <li>
          <strong>Technical University of Munich</strong>
          <p>B.Sc. Informatics, 10/2021 - 09/2023.</p>
        </li>
        <li>
          <strong>Munich International School</strong>
          <p>Grades 10-12, 09/2018 - 06/2021.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section" aria-labelledby="cv-projects-title">
    <div class="container two-column">
      <div>
        <p class="eyebrow">Projects</p>
        <h2 id="cv-projects-title">Selected projects</h2>
      </div>
      <ul class="meta-list">
        <li>
          <strong>Music and video production</strong>
          <p>
            I planned the arrangement, recorded and produced the audio, filmed the video, and
            handled editing and color grading for public YouTube video work in 08/2023 - 10/2023.
          </p>
        </li>
        <li>
          <strong>Top-down roguelike game</strong>
          <p>
            I developed core functionality for a libGDX game project in 12/2024 - 02/2025.
          </p>
        </li>
        <li>
          <strong>Mock database system and application</strong>
          <p>
            I worked on a university team project in 06/2022 - 08/2022 involving user interface
            work, database connection, APIs, and organized sprints.
          </p>
        </li>
        <li>
          <strong>Dijkstra versus A* Extended Essay</strong>
          <p>
            I researched and implemented a comparison of Dijkstra's algorithm and A* on
            procedurally generated mazes in 03/2020 - 11/2020.
          </p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section" aria-labelledby="skills-title">
    <div class="container two-column">
      <div>
        <p class="eyebrow">Skills</p>
        <h2 id="skills-title">Skills</h2>
      </div>
      <div class="stack">
        <div class="stack small">
          <h3>Programming and data</h3>
          <ul class="pill-list">
            <li>Python</li>
            <li>Java</li>
            <li>C#</li>
            <li>SQL</li>
            <li>Swift</li>
            <li>R</li>
          </ul>
        </div>
        <div class="stack small">
          <h3>Music, audio, and media</h3>
          <ul class="pill-list">
            <li>Reaper</li>
            <li>FL Studio</li>
            <li>DaVinci Resolve</li>
            <li>Adobe Photoshop</li>
            <li>Adobe Illustrator</li>
          </ul>
        </div>
        <div class="stack small">
          <h3>Languages</h3>
          <ul class="pill-list">
            <li>Turkish, native</li>
            <li>English, highly proficient</li>
            <li>German, B2</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
