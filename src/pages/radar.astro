---
import BaseLayout from "../layouts/BaseLayout.astro";
import StreamlitRadarEmbed from "../components/StreamlitRadarEmbed.astro";
---

<BaseLayout
  title="Business Development Radar Demo"
  description="Native Streamlit demo for the Business Development Radar portfolio project."
>
  <StreamlitRadarEmbed variant="contained" />
</BaseLayout>

<style is:global>
  body:has(.streamlit-radar-embed--contained) {
    background: #0e1117;
  }

  body:has(.streamlit-radar-embed--contained) .site-footer {
    display: none;
  }

  body:has(.streamlit-radar-embed--contained) .site-main {
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    min-height: 0;
  }

  body:has(.streamlit-radar-embed--contained) .site-shell {
    block-size: 100dvh;
    min-height: 100dvh;
  }
</style>
