---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import FeaturedRadarPanel from "../../components/FeaturedRadarPanel.astro";

const projectOrder = [
  "web-intelligence-rag-pipeline",
  "salesforce-record-label-crm",
  "procedural-planet-generation",
  "dijkstra-vs-a-star",
  "magnetic-liquid-lens-microscope",
];

const getProjectRank = (id: string) => {
  const index = projectOrder.indexOf(id);
  return index === -1 ? projectOrder.length : index;
};

const projects = (await getCollection("projects")).sort(
  (a, b) => getProjectRank(a.id) - getProjectRank(b.id),
);
const secondaryProjects = projects.filter((project) => project.id !== "web-intelligence-rag-pipeline");
---

<BaseLayout
  title="Work"
  description="Draft work index for Can Ocek across software, data, business systems, music, and research."
>
  <header class="page-header container narrow">
    <p class="eyebrow">Work</p>
    <h1>Selected work</h1>
    <p class="lede">
      Technical systems, business platforms, creative tools, and earlier research. The Business
      Development Radar is the flagship project, with a live demo and a deeper case study.
    </p>
  </header>

  <section class="section section--flagship" aria-labelledby="work-radar-title">
    <div class="container">
      <FeaturedRadarPanel eyebrow="Featured work" titleId="work-radar-title" />
    </div>
  </section>

  <section class="section" aria-labelledby="work-drafts-title">
    <div class="container">
      <div class="work-section-heading">
        <p class="eyebrow">Selected projects</p>
        <h2 id="work-drafts-title">Additional project areas</h2>
      </div>
      <div class="project-grid">
        {secondaryProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .work-section-heading {
    max-width: var(--content-width-narrow);
  }

  .project-grid {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
    margin-block-start: var(--space-6);
  }
</style>
