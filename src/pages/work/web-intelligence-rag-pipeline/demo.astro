---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import RadarDemoApp from "../../../components/RadarDemoApp.astro";
---

<BaseLayout
  title="Business Development Radar Demo"
  description="Scoped Business Development Radar demo with pre-generated synthesis, local retrieval, and evidence review."
>
  <section class="demo-stage" aria-labelledby="demo-title">
    <div class="demo-stage__layout">
      <h2 id="demo-title" class="sr-only">Business Development Radar scoped demo</h2>
      <div class="demo-stage__app">
        <RadarDemoApp />
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .site-header,
  .site-footer {
    display: none;
  }

  body {
    background: #0e1117;
  }

  body:has(.demo-stage) {
    overflow-x: hidden;
  }

  body:has(.demo-stage) .site-main {
    min-height: 100vh;
  }
</style>

<style>

  .demo-stage {
    background: #0e1117;
    min-height: 100vh;
  }

  .demo-stage__layout {
    min-height: 100vh;
  }

  .demo-stage__app {
    margin: 0;
    max-width: none;
    padding: 0.5rem;
    width: 100%;
  }

  .sr-only {
    block-size: 1px;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    inline-size: 1px;
    overflow: hidden;
    position: absolute;
    white-space: nowrap;
  }
</style>
