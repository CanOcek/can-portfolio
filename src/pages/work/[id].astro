---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TagList from "../../components/TagList.astro";
import VisualPlaceholder from "../../components/VisualPlaceholder.astro";
import MazePathfindingDemo from "../../components/MazePathfindingDemo.astro";
import RadarDemoTeaser from "../../components/RadarDemoTeaser.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, categories, technologies, role, status, draft, date, cover, visual } = project.data;
const hasCaseStudy = project.body?.trim().length > 0;
const hasInteractiveMazeDemo = project.id === "dijkstra-vs-a-star";
const hasRadarDemoTeaser = project.id === "web-intelligence-rag-pipeline";
---

<BaseLayout title={title} description={description}>
  <header class="page-header container narrow">
    <p class="eyebrow">Work / {draft ? "Draft" : status}</p>
    <h1>{title}</h1>
    <p class="lede">{description}</p>
    {date && <p class="muted with-space">{date}</p>}
  </header>

  {
    hasInteractiveMazeDemo ? (
      <>
        <section class="section interactive-demo-block" aria-labelledby="interactive-demo-title">
          <div class="container interactive-demo-section">
            <div class="interactive-demo-intro">
              <p class="eyebrow">Interactive demo</p>
              <h2 id="interactive-demo-title">Same maze, two search strategies</h2>
              <p>
                Generate a seeded braided maze and watch Dijkstra and A* explore it from the same
                start and destination points. The browser version is a TypeScript modernization of
                the original C# experiment.
              </p>
            </div>
            <MazePathfindingDemo />
          </div>
        </section>

        <section class="section" aria-labelledby="snapshot-title">
          <div class="container two-column">
            <div>
              <p class="eyebrow">Project snapshot</p>
              <h2 id="snapshot-title">Research, code, and modernization</h2>
            </div>
            <div class="snapshot-grid">
              <article class="snapshot-card">
                <p class="snapshot-card__label">Role</p>
                <p>{role}</p>
              </article>
              <article class="snapshot-card">
                <p class="snapshot-card__label">Original implementation</p>
                <p>C# console experiment for maze generation, solver benchmarking, and runtime analysis.</p>
              </article>
              <article class="snapshot-card">
                <p class="snapshot-card__label">Browser demo</p>
                <p>
                  TypeScript and canvas port with seeded mazes, priority queues, and a corrected A*
                  cost model.
                </p>
              </article>
              <article class="snapshot-card">
                <p class="snapshot-card__label">Tools and themes</p>
                <TagList items={technologies} label={`Technologies and themes for ${title}`} />
              </article>
            </div>
          </div>
        </section>
      </>
    ) : (
      <>
        <section class="section section--media" aria-labelledby="visual-title">
          <div class="container project-visual-section">
            <div class="stack">
              <p class="eyebrow">{cover ? "Project cover" : "Visual placeholder"}</p>
              <h2 id="visual-title">{visual.label}</h2>
              <p>{visual.caption}</p>
            </div>
            {
              cover ? (
                <figure class="project-cover">
                  <img src={cover.src} alt={cover.alt} />
                  {cover.caption && <figcaption>{cover.caption}</figcaption>}
                </figure>
              ) : (
                <VisualPlaceholder kind={visual.kind} label={visual.label} caption={visual.caption} />
              )
            }
          </div>
        </section>

        <section class="section" aria-labelledby="context-title">
          <div class="container two-column">
            <div>
              <p class="eyebrow">Context</p>
              <h2 id="context-title">Project frame</h2>
            </div>
            <div class="stack">
              <p>{description}</p>
              <TagList items={categories} label={`Categories for ${title}`} />
            </div>
          </div>
        </section>

        {
          hasRadarDemoTeaser && (
            <section class="section interactive-demo-block" aria-labelledby="radar-demo-title">
              <div class="container interactive-demo-section">
                <div class="interactive-demo-intro">
                  <p class="eyebrow">Interactive demo</p>
                  <h2 id="radar-demo-title">A separate page for the scoped Radar demo</h2>
                  <p>
                    The demo gets its own route so it can grow into a dense retrieval interface
                    without interrupting the case-study narrative.
                  </p>
                </div>
                <RadarDemoTeaser />
              </div>
            </section>
          )
        }

        <section class="section" aria-labelledby="role-title">
          <div class="container two-column">
            <div>
              <p class="eyebrow">Role</p>
              <h2 id="role-title">Current wording</h2>
            </div>
            <p>{role}</p>
          </div>
        </section>

        <section class="section" aria-labelledby="involves-title">
          <div class="container two-column">
            <div>
              <p class="eyebrow">What it involves</p>
              <h2 id="involves-title">Tools and themes</h2>
            </div>
            <TagList items={technologies} label={`Technologies and themes for ${title}`} />
          </div>
        </section>

        <section class="section" aria-labelledby="confirmation-title">
          <div class="container two-column">
            <div>
              <p class="eyebrow">What needs confirmation</p>
              <h2 id="confirmation-title">Before this becomes a case study</h2>
            </div>
            <div class="stack">
              <p class="status-note">{status}</p>
              <p>
                Confirm source documents, public links, screenshots or media, exact dates, personal
                contribution, and any publishable outcomes before expanding this page.
              </p>
            </div>
          </div>
        </section>
      </>
    )
  }

  {
    hasCaseStudy && (
      <section class="section" aria-labelledby="case-study-title">
        <div class="container two-column">
          <div>
            <p class="eyebrow">{hasInteractiveMazeDemo ? "Original research" : "Case study draft"}</p>
            <h2 id="case-study-title">
              {hasInteractiveMazeDemo ? "Method and findings" : "Source-based writeup"}
            </h2>
          </div>
          <article class="project-prose">
            <Content />
          </article>
        </div>
      </section>
    )
  }

  {
    hasInteractiveMazeDemo && (
      <section class="section section--media" aria-labelledby="visual-title">
        <div class="container project-visual-section">
          <div class="stack">
            <p class="eyebrow">Source visual</p>
            <h2 id="visual-title">{visual.label}</h2>
            <p>{visual.caption}</p>
          </div>
          {
            cover ? (
              <figure class="project-cover">
                <img src={cover.src} alt={cover.alt} />
                {cover.caption && <figcaption>{cover.caption}</figcaption>}
              </figure>
            ) : (
              <VisualPlaceholder kind={visual.kind} label={visual.label} caption={visual.caption} />
            )
          }
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .with-space {
    margin-block-start: var(--space-4);
  }

  .project-visual-section {
    align-items: center;
    display: grid;
    gap: var(--space-7);
    grid-template-columns: minmax(0, 0.5fr) minmax(18rem, 1fr);
  }

  .project-cover {
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border-strong);
    border-radius: 16px;
    box-shadow: var(--shadow-soft);
    margin: 0;
    overflow: hidden;
  }

  .project-cover img {
    aspect-ratio: 16 / 10;
    display: block;
    inline-size: 100%;
    object-fit: contain;
  }

  .project-cover figcaption {
    border-block-start: var(--border-subtle);
    color: var(--color-text-subtle);
    font-size: 0.9rem;
    padding: var(--space-3) var(--space-4);
  }

  .interactive-demo-block {
    background:
      linear-gradient(180deg, rgb(17 20 26 / 0.72), rgb(5 6 8 / 0.44)),
      linear-gradient(90deg, transparent, rgb(126 199 190 / 0.08), transparent);
  }

  .interactive-demo-section {
    display: grid;
    gap: var(--space-6);
  }

  .interactive-demo-intro {
    max-width: var(--content-width-narrow);
  }

  .interactive-demo-intro h2 {
    margin-block-end: var(--space-4);
  }

  .snapshot-grid {
    display: grid;
    gap: var(--space-4);
  }

  .snapshot-card {
    background: var(--color-surface);
    border: var(--border-subtle);
    border-radius: var(--radius-md);
    display: grid;
    gap: var(--space-2);
    padding: var(--space-4);
  }

  .snapshot-card__label {
    color: var(--color-cool);
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .project-prose {
    display: grid;
    gap: var(--space-5);
  }

  .project-prose :global(h2),
  .project-prose :global(h3) {
    border-block-start: var(--border-subtle);
    margin-block-start: var(--space-5);
    padding-block-start: var(--space-6);
  }

  .project-prose :global(h2:first-child),
  .project-prose :global(h3:first-child) {
    border-block-start: 0;
    margin-block-start: 0;
    padding-block-start: 0;
  }

  .project-prose :global(ul),
  .project-prose :global(ol) {
    color: var(--color-text-muted);
    display: grid;
    gap: var(--space-2);
    padding-inline-start: var(--space-5);
  }

  .project-prose :global(table) {
    border-collapse: collapse;
    color: var(--color-text-muted);
    display: block;
    inline-size: 100%;
    overflow-x: auto;
  }

  .project-prose :global(th),
  .project-prose :global(td) {
    border-block-end: var(--border-subtle);
    padding: var(--space-2);
    text-align: start;
    white-space: nowrap;
  }

  .project-prose :global(th) {
    color: var(--color-text);
  }

  .project-prose :global(img) {
    background: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    inline-size: 100%;
  }

  .project-prose :global(.benchmark-figure) {
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.035), transparent),
      var(--color-bg-soft);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
    display: grid;
    gap: var(--space-3);
    margin: var(--space-2) 0 var(--space-5);
    overflow: hidden;
    padding: var(--space-3);
  }

  .project-prose :global(.benchmark-figure figcaption) {
    border-block-start: var(--border-subtle);
    color: var(--color-text-subtle);
    font-size: 0.9rem;
    padding: var(--space-3) var(--space-2) 0;
  }

  @media (max-width: 820px) {
    .project-visual-section {
      grid-template-columns: 1fr;
    }
  }
</style>
