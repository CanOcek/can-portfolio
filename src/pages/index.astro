---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";

const featuredOrder = [
  "web-intelligence-rag-pipeline",
  "salesforce-record-label-crm",
  "magnetic-liquid-lens-microscope",
];

const featuredProjects = (await getCollection("projects"))
  .filter((project) => featuredOrder.includes(project.id))
  .sort((a, b) => featuredOrder.indexOf(a.id) - featuredOrder.indexOf(b.id));
---

<BaseLayout
  title="Can Ocek Portfolio"
  description="Draft portfolio foundation for Can Ocek across technology, strategy, and music."
>
  <section class="hero container" aria-labelledby="home-title">
    <div class="hero__content">
      <p class="eyebrow">Portfolio foundation</p>
      <h1 id="home-title">Can &Ouml;cek</h1>
    </div>
    <div class="hero__support">
      <!-- TODO: Replace with final personal positioning copy. -->
      <p class="lede">
        I build systems, shape ideas, and make projects work across technology, strategy, and music.
      </p>
      <p>
        A Management & Technology student at TUM with a computer-science foundation, building a
        portfolio around data systems, platform thinking, music, and creative media as the source
        material is verified.
      </p>
      <div class="button-row" aria-label="Primary actions">
        <a class="button primary" href="/work/">View work</a>
        <a class="button" href="/pdfs/Can%20Ocek%20CV.pdf" download>Download CV</a>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="featured-title">
    <div class="container">
      <p class="eyebrow">First focus</p>
      <h2 id="featured-title">Three areas to build around</h2>
      <div class="home-feature-grid">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="disciplines-title">
    <div class="container two-column">
      <div>
        <p class="eyebrow">Method</p>
        <h2 id="disciplines-title">Working across disciplines</h2>
      </div>
      <div class="grid">
        <p class="lede">
          The common thread is not a list of tools. It is the habit of understanding the system,
          finding the missing pieces, and doing the work needed to connect them.
        </p>
        <p>
          That same pattern connects retrieval systems, CRM modeling, software projects, music
          production, and the practical work of turning unfinished material into something usable.
        </p>
        <div class="system-panel" aria-label="Disciplines connected by the portfolio">
          <div class="signal-card">
            <strong>Systems</strong>
            <span>Data, retrieval, software, and structured technical work.</span>
          </div>
          <div class="signal-rule"></div>
          <div class="signal-card signal-card--right">
            <strong>Strategy</strong>
            <span>Business context, CRM thinking, and project communication.</span>
          </div>
          <div class="signal-rule"></div>
          <div class="signal-card signal-card--left">
            <strong>Sound and media</strong>
            <span>Music performance, production, video, and presentation.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="contact-title">
    <div class="container two-column">
      <div>
        <p class="eyebrow">Next step</p>
        <h2 id="contact-title">Keep the public surface honest</h2>
      </div>
      <div class="stack">
        <p class="lede">
          Contact details, public links, media embeds, and the downloadable CV should be added only
          after the exact public versions are approved.
        </p>
        <div class="button-row">
          <a class="button primary" href="/contact/">Contact status</a>
          <a class="button" href="/cv/">CV outline</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home-feature-grid {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
    margin-block-start: var(--space-6);
  }
</style>
