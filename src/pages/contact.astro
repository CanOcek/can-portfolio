---
import BaseLayout from "../layouts/BaseLayout.astro";

const contactLinks = [
  {
    label: "Email",
    href: "mailto:canocek@gmail.com",
    value: "canocek@gmail.com",
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/can-%C3%B6cek-677620192/",
    value: "linkedin.com/in/can-öcek-677620192",
  },
  {
    label: "GitHub",
    href: "https://github.com/CanOcek",
    value: "github.com/CanOcek",
  },
  {
    label: "YouTube",
    href: "https://www.youtube.com/@CanOcekMusic",
    value: "@CanOcekMusic",
  },
];
---

<BaseLayout
  title="Contact"
  description="Contact Can Ocek for technical work, thesis conversations, business-system projects, music, and creative-technology collaboration."
>
  <header class="page-header container narrow">
    <p class="eyebrow">Contact</p>
    <h1>Let's talk</h1>
    <p class="lede">
      I am open to conversations about technical projects, working-student roles, bachelor's thesis
      topics, business-system work, music, and creative-technology collaboration.
    </p>
    <div class="button-row" aria-label="Contact actions">
      <a class="button primary" href="mailto:canocek@gmail.com">Email me</a>
      <a class="button" href="/pdfs/Can%20Ocek%20CV.pdf" download>Download CV</a>
    </div>
  </header>

  <section class="section" aria-labelledby="contact-links-title">
    <div class="container two-column">
      <div>
        <p class="eyebrow">Links</p>
        <h2 id="contact-links-title">Find me online</h2>
      </div>
      <ul class="meta-list">
        {
          contactLinks.map((link) => (
            <li>
              <strong>{link.label}</strong>
              <p>
                <a href={link.href}>{link.value}</a>
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section" aria-labelledby="contact-routes-title">
    <div class="container two-column">
      <div>
        <p class="eyebrow">Routes</p>
        <h2 id="contact-routes-title">What to contact me about</h2>
      </div>
      <div class="stack">
        <ul class="meta-list">
          <li>
            <strong>Working-student, thesis, and technical projects</strong>
            <p>
              I am open to software, AI-assisted retrieval, data pipelines, automation, bachelor's
              thesis topics, and practical systems that need to be built clearly.
            </p>
          </li>
          <li>
            <strong>Business systems and CRM</strong>
            <p>
              I am interested in work that connects business processes, data models, workflows, and
              technical implementation.
            </p>
          </li>
          <li>
            <strong>Music and creative technology</strong>
            <p>
              I am open to music, audio, video, photography, and creative-technology projects where
              technical execution and presentation both matter.
            </p>
          </li>
        </ul>
        <div class="button-row">
          <a class="button primary" href="/work/">Browse work</a>
          <a class="button" href="/music/">Music work</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
