---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Draft contact page for Can Ocek with public links pending confirmation."
>
  <header class="page-header container narrow">
    <p class="eyebrow">Contact</p>
    <h1>Contact links pending confirmation</h1>
    <p class="lede">
      This page will hold public contact routes for project work, working-student roles, thesis
      conversations, and music or creative-technology collaborations.
    </p>
  </header>

  <section class="section" aria-labelledby="contact-status-title">
    <div class="container two-column">
      <div>
        <p class="eyebrow">Status</p>
        <h2 id="contact-status-title">No fake links</h2>
      </div>
      <div class="stack">
        <p class="status-note">
          Email, GitHub, LinkedIn, and music profiles should be added only after the exact public
          links are confirmed. The CV phone number and private address are not published by default.
        </p>
        <div class="button-row">
          <a class="button" href="/work/">Review work areas</a>
          <a class="button" href="/cv/">View CV outline</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
