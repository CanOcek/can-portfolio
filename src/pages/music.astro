---
import BaseLayout from "../layouts/BaseLayout.astro";
import VisualPlaceholder from "../components/VisualPlaceholder.astro";
---

<BaseLayout
  title="Music"
  description="Draft music page for Can Ocek covering performance, arrangement, production, live audio, and media."
>
  <header class="page-header container narrow">
    <p class="eyebrow">Music</p>
    <h1>Performance and production</h1>
    <p class="lede">
      Music is a central part of this portfolio, not a side note. This page collects performance,
      arrangement, recording, production, live audio, and music-focused video work.
    </p>
  </header>

  <section class="section section--media" aria-labelledby="music-video-title">
    <div class="container music-video-section">
      <div class="stack">
        <p class="eyebrow">Selected media</p>
        <h2 id="music-video-title">Video example</h2>
        <p>
          This public YouTube video is listed in the parsed CV as an example of planned, arranged,
          recorded, produced, filmed, edited, and color-graded music/video work.
        </p>
      </div>
      <div class="media-frame">
        <div class="video-embed">
          <iframe
            src="https://www.youtube-nocookie.com/embed/EWGPLWCOkmI"
            title="Music and video production example by Can Ocek"
            loading="lazy"
            allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="music-areas-title">
    <div class="container">
      <div class="music-section-heading">
        <p class="eyebrow">Areas</p>
        <h2 id="music-areas-title">What belongs here</h2>
      </div>
      <div class="grid three section-offset">
        <article class="panel">
          <p class="panel__meta">Performance</p>
          <h3>Guitar and vocals</h3>
          <p>
            Classical, acoustic, electric, and bass guitar, with vocals to be described in more
            detail after performance material is selected.
          </p>
        </article>
        <article class="panel">
          <p class="panel__meta">Production</p>
          <h3>Recording and arrangement</h3>
          <p>
            Audio planning, arrangement, recording, editing, mixing, and production using tools
            including Reaper and FL Studio.
          </p>
        </article>
        <article class="panel">
          <p class="panel__meta">Media</p>
          <h3>Video and live sound</h3>
          <p>
            Music-focused video, color grading, live setup notes, and selected recordings, with
            video editing and grading work in DaVinci Resolve.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="music-todo-title">
    <div class="container narrow stack">
      <p class="eyebrow">Pending media</p>
      <h2 id="music-todo-title">Media still needs selection</h2>
      <p class="status-note">
        Add only approved recordings, performance videos, stills, and production notes. No embeds
        or release claims should be added until the exact public links are chosen.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="music-slots-title">
    <div class="container">
      <div class="music-section-heading">
        <p class="eyebrow">Future assets</p>
        <h2 id="music-slots-title">Media slots to replace</h2>
      </div>
      <div class="music-slot-grid">
        <VisualPlaceholder
          kind="music"
          label="Performance photo placeholder"
          caption="Replace with a performance photo or strong still from a selected video."
        />
        <VisualPlaceholder
          kind="music"
          label="Production session placeholder"
          caption="Replace with a recording, mixing, or arrangement process image."
        />
        <VisualPlaceholder
          kind="music"
          label="Live setup placeholder"
          caption="Replace with a live audio setup, room, or stage image if available."
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .music-section-heading {
    max-width: var(--content-width-narrow);
  }

  .music-video-section {
    align-items: center;
    display: grid;
    gap: var(--space-7);
    grid-template-columns: minmax(0, 0.62fr) minmax(18rem, 1fr);
  }

  .music-slot-grid {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
    margin-block-start: var(--space-6);
  }

  @media (max-width: 820px) {
    .music-video-section {
      grid-template-columns: 1fr;
    }
  }
</style>
