---
const configuredUrl = import.meta.env.PUBLIC_RADAR_STREAMLIT_URL?.trim();
const rawStreamlitUrl = normalizeRawStreamlitUrl(configuredUrl || "http://localhost:8501");
const embeddedStreamlitUrl = withStreamlitEmbedParam(rawStreamlitUrl);

function normalizeRawStreamlitUrl(url: string) {
  try {
    const parsedUrl = new URL(url);
    parsedUrl.searchParams.delete("embed");
    return parsedUrl.toString();
  } catch {
    const [base, query = ""] = url.split("?");
    const cleanedParams = query
      .split("&")
      .filter((param) => param && !param.toLowerCase().startsWith("embed="));
    return cleanedParams.length ? `${base}?${cleanedParams.join("&")}` : base;
  }
}

function withStreamlitEmbedParam(url: string) {
  try {
    const parsedUrl = new URL(url);
    parsedUrl.searchParams.set("embed", "true");
    return parsedUrl.toString();
  } catch {
    const separator = url.includes("?") ? "&" : "?";
    return `${url}${separator}embed=true`;
  }
}
---

<section class="streamlit-radar-embed" aria-label="Business Development Radar Streamlit embed">
  <header class="streamlit-radar-embed__bar">
    <a class="streamlit-radar-embed__back" href="/work/web-intelligence-rag-pipeline/">Radar case study</a>
    <div class="streamlit-radar-embed__title">
      <p>Business Development Radar</p>
      <span>Native Streamlit embed</span>
    </div>
    <nav class="streamlit-radar-embed__actions" aria-label="Radar app links">
      <a href={rawStreamlitUrl} target="_blank" rel="noreferrer">Open app</a>
    </nav>
  </header>

  <div class="streamlit-radar-embed__frame-shell">
    <iframe
      class="streamlit-radar-embed__frame"
      src={embeddedStreamlitUrl}
      title="Business Development Radar Streamlit app"
      loading="eager"
      referrerpolicy="no-referrer-when-downgrade"
      allow="fullscreen"
    ></iframe>
  </div>
</section>

<style>
  .streamlit-radar-embed {
    block-size: 100vh;
    background: #0e1117;
    color: #f8fafc;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    min-height: 100vh;
    overflow: hidden;
  }

  .streamlit-radar-embed__bar {
    align-items: center;
    background: rgb(14 17 23 / 0.96);
    border-block-end: 1px solid rgb(255 255 255 / 0.12);
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(8rem, 1fr) auto minmax(8rem, 1fr);
    min-height: 3.5rem;
    padding: 0.65rem clamp(0.85rem, 2vw, 1.5rem);
  }

  .streamlit-radar-embed__title {
    display: grid;
    gap: 0.1rem;
    justify-items: center;
    text-align: center;
  }

  .streamlit-radar-embed__title p,
  .streamlit-radar-embed__title span {
    margin: 0;
  }

  .streamlit-radar-embed__title p {
    color: #f8fafc;
    font-size: 0.95rem;
    font-weight: 800;
  }

  .streamlit-radar-embed__title span {
    color: rgb(248 250 252 / 0.68);
    font-size: 0.78rem;
  }

  .streamlit-radar-embed__back,
  .streamlit-radar-embed__actions a {
    align-items: center;
    border: 1px solid rgb(255 255 255 / 0.18);
    border-radius: 6px;
    color: rgb(248 250 252 / 0.86);
    display: inline-flex;
    font-size: 0.86rem;
    font-weight: 700;
    min-height: 2.25rem;
    padding: 0.45rem 0.75rem;
    text-decoration: none;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease;
  }

  .streamlit-radar-embed__back {
    justify-self: start;
  }

  .streamlit-radar-embed__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: flex-end;
  }

  .streamlit-radar-embed__back:hover,
  .streamlit-radar-embed__back:focus-visible,
  .streamlit-radar-embed__actions a:hover,
  .streamlit-radar-embed__actions a:focus-visible {
    background: rgb(255 255 255 / 0.08);
    border-color: rgb(126 199 190 / 0.78);
    color: #ffffff;
  }

  .streamlit-radar-embed__frame-shell {
    block-size: 100%;
    background: #0e1117;
    box-shadow:
      inset 0 10px 0 #0e1117,
      inset 0 -36px 0 #0e1117;
    min-block-size: 0;
    overflow: hidden;
    position: relative;
  }

  .streamlit-radar-embed__frame-shell::before,
  .streamlit-radar-embed__frame-shell::after {
    background: #0e1117;
    content: "";
    display: block;
    inset-inline: 0;
    pointer-events: none;
    position: absolute;
    z-index: 1;
  }

  .streamlit-radar-embed__frame-shell::before {
    height: 10px;
    inset-block-start: 0;
  }

  .streamlit-radar-embed__frame-shell::after {
    height: 36px;
    inset-block-end: 0;
  }

  .streamlit-radar-embed__frame {
    background: #0e1117;
    border: 0;
    display: block;
    height: calc(100% + 24px);
    inset: -12px;
    outline: 0;
    position: absolute;
    width: calc(100% + 24px);
  }

  @media (max-width: 760px) {
    .streamlit-radar-embed__bar {
      grid-template-columns: 1fr;
    }

    .streamlit-radar-embed__title {
      justify-items: start;
      order: -1;
      text-align: start;
    }

    .streamlit-radar-embed__actions {
      justify-content: flex-start;
    }
  }
</style>
