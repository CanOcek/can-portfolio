<section class="maze-demo" data-maze-demo>
  <div class="maze-demo__header">
    <div>
      <p class="maze-demo__eyebrow">Procedural maze pathfinding</p>
      <h3>Dijkstra vs A*</h3>
    </div>
    <div class="maze-demo__actions">
      <button type="button" data-action="new-seed">New maze</button>
      <button type="button" data-action="run">Run</button>
      <button type="button" data-action="pause">Pause</button>
      <button type="button" data-action="reset">Reset</button>
    </div>
  </div>

  <div class="maze-demo__controls" aria-label="Maze controls">
    <label>
      <span>Algorithm</span>
      <select data-control="algorithm">
        <option value="compare">Compare</option>
        <option value="dijkstra">Dijkstra</option>
        <option value="astar">A*</option>
      </select>
    </label>
    <label>
      <span>Size</span>
      <input data-control="size" type="range" min="8" max="60" step="1" value="32" />
      <output data-output="size">32</output>
    </label>
    <label>
      <span>Seed</span>
      <input data-control="seed" type="number" min="1" step="1" value="42" />
    </label>
    <label class="maze-demo__check">
      <input data-control="braid" type="checkbox" checked />
      <span>Braid dead ends</span>
    </label>
    <label>
      <span>Speed</span>
      <input data-control="speed" type="range" min="1" max="240" step="1" value="15" />
      <output data-output="speed">15</output>
    </label>
  </div>

  <div class="maze-demo__grid" data-panel-grid>
    <article class="maze-panel" data-panel="dijkstra">
      <div class="maze-panel__bar">
        <h2>Dijkstra</h2>
        <p class="maze-panel__metric-summary" data-summary="dijkstra">Ready</p>
      </div>
      <canvas data-canvas="dijkstra" width="900" height="900" aria-label="Dijkstra maze visualization"></canvas>
      <div class="maze-panel__metrics" data-metrics="dijkstra" aria-label="Dijkstra metrics"></div>
    </article>

    <article class="maze-panel" data-panel="astar">
      <div class="maze-panel__bar">
        <h2>A*</h2>
        <p class="maze-panel__metric-summary" data-summary="astar">Ready</p>
      </div>
      <canvas data-canvas="astar" width="900" height="900" aria-label="A star maze visualization"></canvas>
      <div class="maze-panel__metrics" data-metrics="astar" aria-label="A star metrics"></div>
    </article>
  </div>

  <div class="maze-demo__legend" aria-label="Visualization legend">
    <span><i class="is-start"></i>Start</span>
    <span><i class="is-goal"></i>Goal</span>
    <span><i class="is-explored"></i>Explored</span>
    <span><i class="is-frontier"></i>Discovered</span>
    <span><i class="is-path"></i>Shortest path</span>
  </div>
</section>

<script>
  import "../scripts/mazePathfindingDemo";
</script>

