---
interface Props {
  items: string[];
  label?: string;
}

const { items, label = "Tags" } = Astro.props;
---

<ul class="tag-list" aria-label={label}>
  {items.map((item) => <li>{item}</li>)}
</ul>

<style>
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tag-list li {
    border: var(--border-subtle);
    border-radius: 999px;
    color: var(--color-text-muted);
    font-size: 0.88rem;
    padding: 0.3rem 0.65rem;
  }
</style>
