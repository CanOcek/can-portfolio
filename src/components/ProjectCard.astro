---
import type { CollectionEntry } from "astro:content";
import TagList from "./TagList.astro";
import VisualPlaceholder from "./VisualPlaceholder.astro";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { title, description, categories, role, status, draft, date, visual } = project.data;
---

<article class="project-card">
  <VisualPlaceholder
    kind={visual.kind}
    label={visual.label}
    caption={visual.caption}
    compact
  />
  <div class="project-card__body">
    <div class="project-card__meta">
      <span>{draft ? "Draft" : status}</span>
      {date && <span>{date}</span>}
    </div>
    <h3>
      <a href={`/work/${project.id}/`}>{title}</a>
    </h3>
    <p>{description}</p>
  </div>
  <div class="project-card__footer">
    <TagList items={categories} label={`Categories for ${title}`} />
    <p class="project-card__role">{role}</p>
  </div>
</article>

<style>
  .project-card {
    background:
      linear-gradient(180deg, rgb(126 199 190 / 0.055), transparent 42%),
      var(--color-surface);
    border: var(--border-subtle);
    border-radius: 14px;
    display: grid;
    gap: var(--space-5);
    min-height: 100%;
    padding: var(--space-4);
    position: relative;
    transition:
      border-color var(--transition-fast),
      transform var(--transition-fast),
      background var(--transition-fast);
  }

  .project-card::before {
    background: linear-gradient(180deg, var(--color-cool), var(--color-accent));
    border-radius: 999px;
    content: "";
    inline-size: 3px;
    inset-block: var(--space-5);
    inset-inline-start: 0;
    opacity: 0;
    position: absolute;
    transition: opacity var(--transition-fast);
  }

  .project-card:hover,
  .project-card:focus-within {
    background:
      linear-gradient(180deg, rgb(126 199 190 / 0.095), transparent 45%),
      var(--color-surface-strong);
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
  }

  .project-card:hover::before,
  .project-card:focus-within::before {
    opacity: 1;
  }

  .project-card__body,
  .project-card__footer {
    display: grid;
    gap: var(--space-4);
    padding-inline: var(--space-1);
  }

  .project-card__meta {
    color: var(--color-cool);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.82rem;
    font-weight: 700;
    gap: var(--space-3);
  }

  .project-card h3 a {
    text-decoration: none;
  }

  .project-card h3 a::after {
    content: "";
    inset: 0;
    position: absolute;
  }

  .project-card h3 {
    position: relative;
  }

  .project-card__role {
    color: var(--color-text-subtle);
    font-size: 0.94rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card:hover,
    .project-card:focus-within {
      transform: none;
    }
  }
</style>
