---
interface Props {
  kind: "pipeline" | "music" | "crm" | "procedural" | "pathfinding";
  label: string;
  caption?: string;
  compact?: boolean;
}

const { kind, label, caption, compact = false } = Astro.props;
---

<figure class:list={["visual-placeholder", `visual-placeholder--${kind}`, { "is-compact": compact }]}>
  <div class="visual-placeholder__stage" role="img" aria-label={label}>
    {
      kind === "pipeline" && (
        <div class="diagram diagram--pipeline" aria-hidden="true">
          <span>Sources</span>
          <i></i>
          <span>Scrape</span>
          <i></i>
          <span>Store</span>
          <i></i>
          <span>Retrieve</span>
        </div>
      )
    }
    {
      kind === "music" && (
        <div class="diagram diagram--music" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
          <span></span>
          <span></span>
        </div>
      )
    }
    {
      kind === "crm" && (
        <div class="diagram diagram--crm" aria-hidden="true">
          <span>Artist</span>
          <span>Release</span>
          <span>Contract</span>
          <span>Royalty</span>
          <span>Campaign</span>
        </div>
      )
    }
    {
      kind === "procedural" && (
        <div class="diagram diagram--procedural" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
      )
    }
    {
      kind === "pathfinding" && (
        <div class="diagram diagram--pathfinding" aria-hidden="true">
          {Array.from({ length: 36 }).map((_, index) => <span class:list={{ "is-path": [2, 8, 14, 15, 21, 27, 28, 34].includes(index) }}></span>)}
        </div>
      )
    }
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .visual-placeholder {
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.04), transparent),
      var(--color-bg-soft);
    border: 1px solid var(--color-border-strong);
    border-radius: 16px;
    box-shadow: var(--shadow-soft);
    margin: 0;
    overflow: hidden;
  }

  .visual-placeholder__stage {
    align-items: center;
    aspect-ratio: 16 / 10;
    background:
      linear-gradient(135deg, rgb(126 199 190 / 0.12), transparent 42%),
      linear-gradient(315deg, rgb(213 139 84 / 0.11), transparent 44%),
      var(--color-surface);
    display: grid;
    min-height: 13rem;
    padding: var(--space-5);
    position: relative;
  }

  .visual-placeholder__stage::before {
    background:
      linear-gradient(90deg, rgb(255 255 255 / 0.055) 1px, transparent 1px),
      linear-gradient(180deg, rgb(255 255 255 / 0.055) 1px, transparent 1px);
    background-size: 24px 24px;
    content: "";
    inset: 0;
    opacity: 0.45;
    position: absolute;
  }

  .visual-placeholder figcaption {
    border-block-start: var(--border-subtle);
    color: var(--color-text-subtle);
    font-size: 0.9rem;
    padding: var(--space-3) var(--space-4);
  }

  .visual-placeholder.is-compact {
    border-radius: 12px;
    box-shadow: none;
  }

  .visual-placeholder.is-compact .visual-placeholder__stage {
    min-height: 10rem;
    padding: var(--space-4);
  }

  .visual-placeholder.is-compact figcaption {
    display: none;
  }

  .diagram {
    position: relative;
    z-index: 1;
  }

  .diagram--pipeline {
    align-items: center;
    display: grid;
    gap: var(--space-3);
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
  }

  .diagram--pipeline span,
  .diagram--crm span {
    background: rgb(5 6 8 / 0.72);
    border: var(--border-subtle);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-size: 0.78rem;
    font-weight: 700;
    padding: var(--space-3);
    text-align: center;
  }

  .diagram--pipeline i {
    background: var(--color-cool);
    block-size: 2px;
    inline-size: 24px;
  }

  .diagram--music {
    align-items: end;
    display: grid;
    gap: var(--space-3);
    grid-template-columns: repeat(5, 1fr);
    min-height: 9rem;
  }

  .diagram--music span {
    background: linear-gradient(180deg, var(--color-accent-strong), var(--color-cool));
    border-radius: 999px 999px 8px 8px;
    min-height: 34%;
  }

  .diagram--music span:nth-child(2) {
    min-height: 68%;
  }

  .diagram--music span:nth-child(3) {
    min-height: 48%;
  }

  .diagram--music span:nth-child(4) {
    min-height: 88%;
  }

  .diagram--music span:nth-child(5) {
    min-height: 56%;
  }

  .diagram--crm {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: repeat(6, 1fr);
  }

  .diagram--crm span:first-child {
    grid-column: 1 / 4;
  }

  .diagram--crm span:nth-child(2) {
    grid-column: 4 / 7;
  }

  .diagram--crm span:nth-child(3) {
    grid-column: 1 / 3;
  }

  .diagram--crm span:nth-child(4) {
    grid-column: 3 / 5;
  }

  .diagram--crm span:nth-child(5) {
    grid-column: 5 / 7;
  }

  .diagram--procedural {
    min-height: 10rem;
  }

  .diagram--procedural span {
    background:
      radial-gradient(circle at 38% 34%, rgb(244 241 234 / 0.22), transparent 12%),
      radial-gradient(circle at 58% 64%, rgb(126 199 190 / 0.2), transparent 15%),
      linear-gradient(135deg, rgb(122 167 255 / 0.28), rgb(213 139 84 / 0.2));
    border: 1px solid rgb(244 241 234 / 0.12);
    border-radius: 50%;
    display: block;
    position: absolute;
  }

  .diagram--procedural span:first-child {
    block-size: 7.8rem;
    inline-size: 7.8rem;
    inset-block-start: 50%;
    inset-inline-start: 50%;
    transform: translate(-50%, -50%);
  }

  .diagram--procedural span:nth-child(2) {
    block-size: 2.6rem;
    inline-size: 2.6rem;
    inset-block-start: 12%;
    inset-inline-end: 18%;
  }

  .diagram--procedural span:nth-child(3) {
    block-size: 1.7rem;
    inline-size: 1.7rem;
    inset-block-end: 16%;
    inset-inline-start: 14%;
  }

  .diagram--pathfinding {
    display: grid;
    gap: 5px;
    grid-template-columns: repeat(6, 1fr);
  }

  .diagram--pathfinding span {
    aspect-ratio: 1;
    background: rgb(244 241 234 / 0.08);
    border: 1px solid rgb(244 241 234 / 0.08);
    border-radius: 4px;
  }

  .diagram--pathfinding span.is-path {
    background: var(--color-cool);
    box-shadow: 0 0 24px rgb(126 199 190 / 0.42);
  }

  .visual-placeholder.is-compact .diagram--pipeline {
    gap: var(--space-2);
  }

  .visual-placeholder.is-compact .diagram--pipeline span,
  .visual-placeholder.is-compact .diagram--crm span {
    font-size: 0.68rem;
    padding: var(--space-2);
  }

  .visual-placeholder.is-compact .diagram--music {
    min-height: 6.5rem;
  }

  .visual-placeholder.is-compact .diagram--procedural {
    min-height: 7rem;
  }

  .visual-placeholder.is-compact .diagram--procedural span:first-child {
    block-size: 5.3rem;
    inline-size: 5.3rem;
  }

  @media (max-width: 700px) {
    .diagram--pipeline {
      grid-template-columns: 1fr;
    }

    .diagram--pipeline i {
      block-size: 16px;
      inline-size: 2px;
      justify-self: center;
    }
  }
</style>
